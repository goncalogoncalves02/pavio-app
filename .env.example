# Origem pública canónica, sem caminho. Em falta, usa localhost e bloqueia indexação.
NEXT_PUBLIC_SITE_URL=https://exemplo.pt

# Número WhatsApp em formato internacional. Deixe vazio até existir um contacto real.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# URL completa do perfil de Instagram. Deixe vazio até existir um perfil real.
NEXT_PUBLIC_INSTAGRAM_URL=

# Zona real onde pode existir entrega local ou recolha (por exemplo: "Coimbra e arredores").
NEXT_PUBLIC_SERVICE_AREA=
