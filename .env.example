# Origem pública canónica, sem caminho (formato: https://seudominio.pt). Em falta, usa localhost e bloqueia indexação.
NEXT_PUBLIC_SITE_URL=

# Número WhatsApp em formato internacional. Deixe vazio até existir um contacto real.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# URL completa do perfil de Instagram. Deixe vazio até existir um perfil real.
NEXT_PUBLIC_INSTAGRAM_URL=

# Zona real de atendimento/descoberta local. Não altera a recolha, que permanece em Setúbal.
NEXT_PUBLIC_SERVICE_AREA=Setúbal
